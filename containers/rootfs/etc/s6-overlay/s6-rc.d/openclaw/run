#!/command/execlineb -P
with-contenv
s6-notifyoncheck -d
s6-envuidgid node
export TERM xterm-256color
export COLORTERM truecolor
export HOME /home/node
export XDG_CONFIG_HOME /home/node/.config
export XDG_CACHE_HOME /home/node/.cache
export XDG_DATA_HOME /home/node/.local/share
export XDG_STATE_HOME /home/node/.local/state
export ZEROCLAW_GATEWAY_PORT 8080
export PIP_CACHE_DIR /home/node/.cache/pip
export npm_config_cache /home/node/.cache/npm
export GOPATH /home/node/.go
export GOCACHE /home/node/.cache/go-build
export GOMODCACHE /home/node/.cache/go-mod
export CARGO_HOME /home/node/.cargo
s6-setuidgid node
cd /app
node openclaw.mjs gateway --allow-unconfigured --foreground